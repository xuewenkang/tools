{
  "name": "工具集合",
  "appid": "__UNI__COLLAGE",
  "description": "面向微信小程序的本地图片工具集合",
  "versionName": "1.0.0",
  "versionCode": "100",
  "uni-app-x": {},
  "mp-weixin": {
    "appid": "touristappid",
    "setting": {
      "urlCheck": false,
      "es6": true,
      "postcss": true,
      "minified": true
    },
     "requiredPrivateInfos": [
    "getLocation"
  ],
    "usingComponents": true,
    "permission": {
      "scope.userLocation": {
        "desc": "用于获取当前位置并展示实时天气"
      },
      "scope.writePhotosAlbum": {
        "desc": "用于保存导出的拼图图片到相册"
      }
    }
  }
}
