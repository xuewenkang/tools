<script lang="uts">
type UserProfile = {
  name: string
  birthday: string
  zodiac: string
}

function todayKey(): string {
  const now = new Date()
  const y = now.getFullYear()
  const m = `${now.getMonth() + 1}`.padStart(2, '0')
  const d = `${now.getDate()}`.padStart(2, '0')
  return `${y}-${m}-${d}`
}

function safeText(value: any): string {
  if (value == null) return ''
  return `${value}`.trim()
}

function pickSiliconFlowText(data: any): string {
  return safeText(data?.choices?.[0]?.message?.content)
}

function zodiacFromBirthday(birthday: string): string {
  const parts = birthday.split('-')
  if (parts.length < 3) return '星座'
  const month = Number(parts[1])
  const day = Number(parts[2])
  const value = month * 100 + day
  if (value >= 321 && value <= 419) return '白羊座'
  if (value >= 420 && value <= 520) return '金牛座'
  if (value >= 521 && value <= 621) return '双子座'
  if (value >= 622 && value <= 722) return '巨蟹座'
  if (value >= 723 && value <= 822) return '狮子座'
  if (value >= 823 && value <= 922) return '处女座'
  if (value >= 923 && value <= 1023) return '天秤座'
  if (value >= 1024 && value <= 1122) return '天蝎座'
  if (value >= 1123 && value <= 1221) return '射手座'
  if (value >= 1222 || value <= 119) return '摩羯座'
  if (value >= 120 && value <= 218) return '水瓶座'
  return '双鱼座'
}

function zodiacEnglish(zodiac: string): string {
  if (zodiac == '白羊座') return 'Aries'
  if (zodiac == '金牛座') return 'Taurus'
  if (zodiac == '双子座') return 'Gemini'
  if (zodiac == '巨蟹座') return 'Cancer'
  if (zodiac == '狮子座') return 'Leo'
  if (zodiac == '处女座') return 'Virgo'
  if (zodiac == '天秤座') return 'Libra'
  if (zodiac == '天蝎座') return 'Scorpio'
  if (zodiac == '射手座') return 'Sagittarius'
  if (zodiac == '摩羯座') return 'Capricorn'
  if (zodiac == '水瓶座') return 'Aquarius'
  if (zodiac == '双鱼座') return 'Pisces'
  return 'Zodiac'
}

export default {
  data() {
    return {
      statusBarHeight: 44,
      dayKey: todayKey(),
      profileName: '',
      profileBirthday: '',
      profileZodiac: '',
      zodiacEn: 'Zodiac',
      isDrawing: false,
      fortuneDrawn: false,
      ritualTextIndex: 0,
      fortuneText: '',
      fortuneGood: '整理心情',
      fortuneAvoid: '过度内耗',
      fortuneColor: '月光金',
      rarity: 'rare',
      rarityLabel: '稀有',
      luckyNumber: '7',
      energyIndex: '86',
      luckStars: '★★★★☆',
      ritualTexts: [
        '✨ 正在连接星辰...',
        '🌙 正在解析今日命运...',
        '💖 宇宙正在回应你...',
        '⭐ 正在抽取属于你的星卡...',
      ] as string[],
    }
  },
  onShow() {
    const sysInfo = uni.getSystemInfoSync()
    this.statusBarHeight = (sysInfo.statusBarHeight as number) ?? 44
    this.loadUserProfile()
  },
  methods: {
    loadUserProfile() {
      const saved = uni.getStorageSync('userProfile') as any
      const name = safeText(saved?.name)
      const birthday = safeText(saved?.birthday)
      if (name.length == 0 || birthday.length == 0) {
        this.profileName = ''
        this.profileBirthday = ''
        this.profileZodiac = ''
        this.zodiacEn = 'Zodiac'
        return
      }
      this.profileName = name
      this.profileBirthday = birthday
      this.profileZodiac = safeText(saved?.zodiac)
      if (this.profileZodiac.length == 0) this.profileZodiac = zodiacFromBirthday(birthday)
      this.zodiacEn = zodiacEnglish(this.profileZodiac)
      this.loadCachedFortune()
    },
    getSiliconFlowKey(): string {
      const key = uni.getStorageSync('siliconFlowApiKey')
      return safeText(key)
    },
    drawFortune() {
      if (this.isDrawing) return
      if (this.profileZodiac.length == 0) {
        uni.showToast({ title: '先到设置里填写名字和生日', icon: 'none' })
        return
      }
      const cachedKey = `daily_fortune_${this.dayKey}_${this.profileZodiac}`
      const cached = safeText(uni.getStorageSync(cachedKey))
      if (cached.length > 0) {
        this.playRitual(cached)
        return
      }
      const key = this.getSiliconFlowKey()
      if (key.length == 0) {
        uni.showToast({ title: '请先在设置中填写硅基流动 Key', icon: 'none' })
        return
      }
      this.startRitual()
      this.callSiliconFlow(
        key,
        `请为${this.profileName}生成${this.dayKey}${this.profileZodiac}今日星座运势。输出4行：运势：一句温柔准确的分析；宜：一个具体行动；不宜：一个具体避免事项；幸运色：一个颜色。不要表情符号。`,
        (text: string) => {
          uni.setStorageSync(cachedKey, text)
          setTimeout(() => {
            this.finishRitual(text)
          }, 2200)
        },
        () => {
          this.isDrawing = false
          uni.showToast({ title: '星辰暂时失联了', icon: 'none' })
        },
        180,
        0.8,
      )
    },
    startRitual() {
      this.isDrawing = true
      this.ritualTextIndex = 0
      setTimeout(() => { if (this.isDrawing) this.ritualTextIndex = 1 }, 1000)
      setTimeout(() => { if (this.isDrawing) this.ritualTextIndex = 2 }, 2000)
      setTimeout(() => { if (this.isDrawing) this.ritualTextIndex = 3 }, 3000)
      setTimeout(() => { if (this.isDrawing) this.ritualTextIndex = 0 }, 4000)
    },
    playRitual(text: string) {
      this.startRitual()
      setTimeout(() => {
        this.finishRitual(text)
      }, 2600)
    },
    finishRitual(text: string) {
      this.isDrawing = false
      this.applyFortune(text)
    },
    loadCachedFortune() {
      if (this.profileZodiac.length == 0) return
      const cachedKey = `daily_fortune_${this.dayKey}_${this.profileZodiac}`
      const cached = safeText(uni.getStorageSync(cachedKey))
      if (cached.length > 0) this.applyFortune(cached)
    },
    applyFortune(text: string) {
      this.fortuneText = text
      this.fortuneDrawn = true
      const lines = text.split('\n')
      for (let i = 0; i < lines.length; i++) {
        const line = lines[i]
        if (line.indexOf('宜') >= 0 && line.indexOf('不宜') < 0) this.fortuneGood = line.replace('宜：', '').replace('宜:', '').trim()
        if (line.indexOf('不宜') >= 0) this.fortuneAvoid = line.replace('不宜：', '').replace('不宜:', '').trim()
        if (line.indexOf('幸运色') >= 0) this.fortuneColor = line.replace('幸运色：', '').replace('幸运色:', '').trim()
      }
      this.luckyNumber = `${(this.dayKey.length + this.profileZodiac.length + this.profileName.length) % 9 + 1}`
      this.energyIndex = `${82 + ((this.profileZodiac.length + this.profileName.length) % 14)}`
      this.rarity = this.energyIndex >= '92' ? 'legend' : this.energyIndex >= '88' ? 'epic' : 'rare'
      this.rarityLabel = this.rarity == 'legend' ? '传说' : this.rarity == 'epic' ? '史诗' : '稀有'
      this.luckStars = this.rarity == 'legend' ? '★★★★★' : this.rarity == 'epic' ? '★★★★☆' : '★★★☆☆'
    },
    callSiliconFlow(key: string, prompt: string, successCb: (text: string) => void, failCb: () => void, maxTokens: number = 256, temperature: number = 0.7) {
      uni.request({
        url: 'https://api.siliconflow.cn/v1/chat/completions',
        method: 'POST',
        timeout: 30000,
        header: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${key}`,
        },
        data: {
          model: 'deepseek-ai/DeepSeek-V4-Pro',
          messages: [
            {
              role: 'user',
              content: prompt,
            },
          ],
          temperature,
          max_tokens: maxTokens,
        },
        success: (res) => {
          const data = res.data as any
          if (res.statusCode == 429) {
            uni.showToast({ title: '今日免费额度暂不可用', icon: 'none' })
            failCb()
            return
          }
          const text = pickSiliconFlowText(data)
          if (text.length == 0) {
            failCb()
            return
          }
          successCb(text)
        },
        fail: () => {
          failCb()
        },
      })
    },
  },
}
</script>

<template>
  <view class="page" :class="rarity">
    <view class="aurora aurora-one"></view>
    <view class="aurora aurora-two"></view>
    <view class="bokeh bokeh-one"></view>
    <view class="bokeh bokeh-two"></view>
    <view class="bokeh bokeh-three"></view>
    <view class="cloud cloud-left"></view>
    <view class="cloud cloud-right"></view>
    <view class="meteor meteor-one"></view>
    <view class="meteor meteor-two"></view>
    <view class="star-field">
      <view class="star s1"></view>
      <view class="star s2"></view>
      <view class="star s3"></view>
      <view class="star s4"></view>
      <view class="star s5"></view>
      <view class="star s6"></view>
      <view class="star s7"></view>
      <view class="star s8"></view>
    </view>

    <view class="nav" :style="{ paddingTop: statusBarHeight + 'px' }">
      <text class="nav-title">{{ fortuneDrawn ? '我的星卡' : '星卡抽取' }}</text>
      <text class="nav-subtitle">Galaxy Tarot · 今天的星象结引，专属于你的星辰礼物</text>
    </view>

    <scroll-view scroll-y class="scroll">
      <view class="hero">
        <view class="tarot-shell">
          <view class="tarot-card" :class="{ revealed: fortuneDrawn, drawing: isDrawing }">
            <view class="card-glass"></view>
            <view class="card-shimmer"></view>
            <view class="corner-star corner-tl"></view>
            <view class="corner-star corner-tr"></view>
            <view class="corner-star corner-bl"></view>
            <view class="corner-star corner-br"></view>
            <view class="moon"></view>
            <view class="sun"></view>
            <view class="magic-ring ring-one"></view>
            <view class="magic-ring ring-two"></view>
            <view class="magic-ring ring-three"></view>
            <view class="zodiac-wheel">
              <view class="wheel-line line-a"></view>
              <view class="wheel-line line-b"></view>
              <view class="wheel-line line-c"></view>
              <view class="wheel-dot dot-a"></view>
              <view class="wheel-dot dot-b"></view>
              <view class="wheel-dot dot-c"></view>
              <view class="crystal"><text>{{ profileZodiac.length > 0 ? profileZodiac.slice(0, 1) : '星' }}</text></view>
            </view>
            <view class="card-caption">
              <text>{{ fortuneDrawn ? profileZodiac : 'PINK TAROT' }}</text>
              <text>{{ fortuneDrawn ? zodiacEn : 'Touch the starlight' }}</text>
            </view>
          </view>
        </view>

        <button class="draw-button" @click="drawFortune">
          <view class="button-ripple"></view>
          <text>{{ isDrawing ? '正在解析今日命运' : fortuneDrawn ? '再次查看今日星卡' : '✦ 抽取今日星卡' }}</text>
        </button>
        <text class="hint-text">点击卡牌开启命运指引</text>
      </view>

      <view v-if="fortuneDrawn" class="result-layout">
        <view class="result-card" :class="rarity">
          <view class="result-glow"></view>
          <view class="result-frame"></view>
          <text class="congrats">恭喜你</text>
          <text class="result-title">{{ profileZodiac }}</text>
          <text class="result-en">{{ zodiacEn }}</text>
          <text class="rating">{{ luckStars }}</text>
          <view class="result-oracle">
            <view class="oracle-ring"></view>
            <view class="oracle-moon moon-left"></view>
            <view class="oracle-moon moon-right"></view>
          </view>
          <text class="theme-text">{{ fortuneText }}</text>
          <view class="quick-grid">
            <view><text>幸运色</text><text>{{ fortuneColor }}</text></view>
            <view><text>幸运数字</text><text>{{ luckyNumber }}</text></view>
            <view><text>能量指数</text><text>{{ energyIndex }}%</text></view>
            <view><text>幸运指数</text><text>{{ luckStars }}</text></view>
          </view>
        </view>

        <view class="module-grid">
          <view class="module module-1"><view class="module-icon">✦</view><view><text>今日关键词</text><text>{{ fortuneGood }}</text></view></view>
          <view class="module module-2"><view class="module-icon">♡</view><view><text>爱情运势</text><text>把话说柔软，靠近会更自然。</text></view></view>
          <view class="module module-3"><view class="module-icon">▣</view><view><text>事业运势</text><text>{{ fortuneGood }}</text></view></view>
          <view class="module module-4"><view class="module-icon">◌</view><view><text>财运分析</text><text>适合稳住节奏，少做冲动选择。</text></view></view>
          <view class="module module-5"><view class="module-icon">●</view><view><text>幸运颜色</text><text>{{ fortuneColor }}</text></view></view>
          <view class="module module-6"><view class="module-icon">3</view><view><text>幸运数字</text><text>{{ luckyNumber }}</text></view></view>
          <view class="module module-7"><view class="module-icon">☾</view><view><text>今日建议</text><text>{{ fortuneGood }}</text></view></view>
          <view class="module module-8"><view class="module-icon">♡</view><view><text>心灵寄语</text><text>愿你的温柔被世界温柔以待，所有美好都会如期而至。</text></view></view>
        </view>
      </view>

      <view class="bottom-safe"></view>
    </scroll-view>

    <view v-if="isDrawing" class="ritual-mask">
      <view class="ritual-aurora"></view>
      <view class="ritual-flash"></view>
      <view class="petal p1"></view>
      <view class="petal p2"></view>
      <view class="petal p3"></view>
      <view class="petal p4"></view>
      <view class="ritual-stage">
        <view class="ritual-ring ritual-ring-a"></view>
        <view class="ritual-ring ritual-ring-b"></view>
        <view class="ritual-ring ritual-ring-c"></view>
        <view class="energy-line energy-a"></view>
        <view class="energy-line energy-b"></view>
        <view class="ritual-card">
          <view class="ritual-card-face">
            <view class="ritual-symbol"></view>
            <text>{{ profileZodiac.length > 0 ? profileZodiac.slice(0, 1) : '星' }}</text>
          </view>
        </view>
      </view>
      <text class="ritual-text">{{ ritualTexts[ritualTextIndex] }}</text>
      <text class="ritual-subtext">宇宙正在回应你的召唤...</text>
      <view class="ritual-dots"><text>•</text><text>•</text><text>•</text></view>
    </view>
  </view>
</template>

<style>
