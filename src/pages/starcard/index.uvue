  min-height: 100vh;
  color: #3b3555;
  background: linear-gradient(180deg, #ffeaf5 0%, #f8eeff 52%, #fff8fd 100%);
  overflow: hidden;
}

.aurora,
.bokeh,
.cloud,
.meteor,
.star-field {
  position: fixed;
  pointer-events: none;
}

.aurora {
  width: 760rpx;
  height: 520rpx;
  border-radius: 50%;
  filter: blur(28rpx);
  opacity: 0.46;
  transform: translate3d(0, 0, 0);
  animation: auroraFlow 18s ease-in-out infinite;
}

.aurora-one {
  left: -220rpx;
  top: 80rpx;
  background: linear-gradient(135deg, rgba(255, 184, 232, 0.74), rgba(231, 198, 255, 0.40), rgba(255, 255, 255, 0));
}

.aurora-two {
  right: -260rpx;
  top: 360rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0), rgba(196, 167, 255, 0.34), rgba(255, 198, 226, 0.52));
  animation-delay: 5s;
}

.bokeh {
  border-radius: 50%;
  filter: blur(8rpx);
  background: rgba(255, 255, 255, 0.64);
  animation: bokehFloat 16s ease-in-out infinite;
}

.bokeh-one { left: 42rpx; top: 220rpx; width: 168rpx; height: 168rpx; }
.bokeh-two { right: 28rpx; top: 520rpx; width: 220rpx; height: 220rpx; animation-delay: 3s; }
.bokeh-three { left: 210rpx; bottom: 160rpx; width: 132rpx; height: 132rpx; animation-delay: 6s; }

.cloud {
  width: 440rpx;
  height: 120rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
  filter: blur(16rpx);
  bottom: 86rpx;
  animation: cloudFloat 20s ease-in-out infinite;
}

.cloud-left { left: -100rpx; }
.cloud-right { right: -130rpx; bottom: 126rpx; animation-delay: 4s; }

.star-field {
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
}

.star {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 0 22rpx rgba(255, 255, 255, 0.96), 0 0 42rpx rgba(255, 184, 232, 0.50);
  animation: starTwinkle 4.8s ease-in-out infinite;
}

.s1 { left: 72rpx; top: 166rpx; }
.s2 { right: 108rpx; top: 232rpx; animation-delay: 700ms; }
.s3 { left: 180rpx; top: 462rpx; animation-delay: 1.2s; }
.s4 { right: 64rpx; top: 662rpx; animation-delay: 1.9s; }
.s5 { left: 90rpx; bottom: 296rpx; animation-delay: 2.4s; }
.s6 { right: 210rpx; bottom: 196rpx; animation-delay: 3s; }
.s7 { left: 330rpx; top: 118rpx; animation-delay: 3.6s; }
.s8 { right: 300rpx; bottom: 430rpx; animation-delay: 4.1s; }

.meteor {
  width: 180rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.96));
  opacity: 0;
  transform: rotate(-25deg);
  animation: meteorFly 11s ease-in-out infinite;
}

.meteor-one { right: -80rpx; top: 260rpx; }
.meteor-two { right: -130rpx; top: 620rpx; animation-delay: 5.2s; }

.nav {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 20;
  padding: 22rpx 32rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(180deg, rgba(255, 234, 245, 0.88), rgba(255, 234, 245, 0));
}

.nav-title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  text-shadow: 0 4rpx 24rpx rgba(191, 92, 154, 0.28);
}

.nav-subtitle {
  margin-top: 8rpx;
  color: rgba(116, 106, 149, 0.72);
  font-size: 23rpx;
  font-weight: 500;
  text-align: center;
}

.scroll {
  position: relative;
  z-index: 5;
  height: 100vh;
  padding: 188rpx 32rpx 0;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tarot-shell {
  width: 100%;
  display: flex;
  justify-content: center;
  transform: translate3d(0, 0, 0);
}

.tarot-card {
  position: relative;
  width: 72vw;
  height: 600rpx;
  max-width: 540rpx;
  border-radius: 36rpx;
  overflow: hidden;
  background: linear-gradient(150deg, rgba(255, 255, 255, 0.42), rgba(231, 198, 255, 0.32) 44%, rgba(255, 184, 232, 0.34));
  border: 3rpx solid rgba(255, 255, 255, 0.62);
  box-shadow: 0 30rpx 90rpx rgba(214, 118, 184, 0.24), 0 0 60rpx rgba(255, 255, 255, 0.58), inset 0 0 40rpx rgba(255, 255, 255, 0.28);
  transform: translate3d(0, 0, 0);
  animation: cardFloat 4s ease-in-out infinite;
}

.tarot-card::before {
  content: '';
  position: absolute;
  inset: 12rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 219, 173, 0.62);
  box-shadow: inset 0 0 24rpx rgba(255, 255, 255, 0.42);
}

.tarot-card.drawing {
  animation: cardInvoke 1.2s cubic-bezier(.2,.8,.2,1) infinite;
}

.tarot-card.revealed {
  animation: cardReveal 700ms cubic-bezier(.18,.9,.22,1.2) both, cardFloat 4s ease-in-out 700ms infinite;
}

.card-glass {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 35% 16%, rgba(255, 255, 255, 0.72), transparent 26%), radial-gradient(circle at 70% 70%, rgba(255, 184, 232, 0.42), transparent 34%);
}

.card-shimmer {
  position: absolute;
  left: -140rpx;
  top: 0;
  width: 104rpx;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.74), transparent);
  transform: skewX(-18deg);
  animation: shimmer 5s ease-in-out infinite;
}

.corner-star {
  position: absolute;
  width: 30rpx;
  height: 30rpx;
  z-index: 2;
}

.corner-star::before,
.corner-star::after {
  content: '';
  position: absolute;
  left: 13rpx;
  top: 0;
  width: 4rpx;
  height: 30rpx;
  border-radius: 999rpx;
  background: #fff1b8;
  box-shadow: 0 0 18rpx rgba(255, 241, 184, 0.82);
}

.corner-star::after {
  transform: rotate(90deg);
}

.corner-tl { left: 42rpx; top: 42rpx; }
.corner-tr { right: 42rpx; top: 42rpx; }
.corner-bl { left: 42rpx; bottom: 42rpx; }
.corner-br { right: 42rpx; bottom: 42rpx; }

.moon {
  position: absolute;
  left: 50%;
  top: 72rpx;
  width: 56rpx;
  height: 56rpx;
  margin-left: -28rpx;
  border-radius: 50%;
  background: #fff1b8;
  box-shadow: 0 0 36rpx rgba(255, 241, 184, 0.68);
}

.moon::after {
  content: '';
  position: absolute;
  left: 18rpx;
  top: 0;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: rgba(215, 149, 219, 0.86);
}

.sun {
  position: absolute;
  left: 50%;
  bottom: 78rpx;
  width: 54rpx;
  height: 54rpx;
  margin-left: -27rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #fff8dc, #ffc6df);
  box-shadow: 0 0 34rpx rgba(255, 198, 223, 0.72);
}

.magic-ring {
