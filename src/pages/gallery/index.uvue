  100% { transform: translateX(340rpx) translateY(-36rpx); opacity: 0; }
}

@keyframes starBlink {
  0%, 100% { opacity: 0.4; transform: scale(0.82); }
  50% { opacity: 1; transform: scale(1.1); }
}

@keyframes petalFloat {
