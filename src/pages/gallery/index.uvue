  18% { opacity: 1; }
  100% { transform: translateY(250rpx) rotate(8deg); opacity: 0; }
}

@keyframes ripple {
  0% { transform: scale(0.25); opacity: 0; }
  24% { opacity: 0.5; }
  100% { transform: scale(1.8); opacity: 0; }
}

