<script lang="uts">
type WeatherMood = {
  title: string
  desc: string
  className: string
}

const moods: WeatherMood[] = [
  { title: '晴光', desc: '适合把普通的一天整理得亮一点', className: 'sunny' },
  { title: '云柔', desc: '慢一点也很好 今天先完成一件小事', className: 'cloudy' },
  { title: '微雨', desc: '把情绪放轻 给自己一点安静时间', className: 'rainy' },
]

const fallbackLines: string[] = [
  '知之者不如好之者 好之者不如乐之者 - 孔子',
  '生活明朗 万物可爱 - 汪曾祺',
  '我们必须习惯 站在人生的交叉路口 - 鲁迅',
]

function todayKey(): string {
  const now = new Date()
  const y = now.getFullYear()
  const m = `${now.getMonth() + 1}`.padStart(2, '0')
  const d = `${now.getDate()}`.padStart(2, '0')
  return `${y}-${m}-${d}`
}

function safeText(value: any): string {
  if (value == null) return ''
  return `${value}`.trim()
}

function pickSiliconFlowText(data: any): string {
  return safeText(data?.choices?.[0]?.message?.content)
}

export default {
  data() {
    return {
      statusBarHeight: 44,
      navOffset: 148,
      dayKey: todayKey(),
      mood: moods[0],
      encouragement: fallbackLines[0],
      story: '',
      storyExpanded: false,
      isGeneratingLine: false,
      isGeneratingStory: false,
      storyTipVisible: false,
      weatherCity: '当前位置',
      weatherMetaLabel: '每日氛围',
      weatherTemp: '--',
      weatherHumidity: '--',
      weatherWind: '--',
      weatherAirQuality: '氛围',
    }
  },
  onShow() {
    const sysInfo = uni.getSystemInfoSync()
    this.statusBarHeight = (sysInfo.statusBarHeight as number) ?? 44
    this.pickDailyMood()
    this.loadRealWeather()
    this.loadDailyLine()
  },
  methods: {
    pickDailyMood() {
      const now = new Date()
      const index = (now.getDate() + now.getMonth()) % moods.length
      this.mood = moods[index]
      this.encouragement = fallbackLines[index]
    },
    loadRealWeather(force: boolean = false) {
      const cached = uni.getStorageSync('todayWeather') as any
      const now = Date.now()
      if (!force && cached != null && cached.time != null && now - cached.time < 30 * 60 * 1000) {
        console.log('[weather] use cached weather')
        this.applyWeather(cached.data)
        return
      }
      this.weatherMetaLabel = '定位中'
      uni.authorize({
        scope: 'scope.userLocation',
        success: () => {
          this.requestLocationAndWeather()
        },
        fail: () => {
          console.log('[weather] location authorize failed')
          this.weatherMetaLabel = '未授权定位'
        },
      })
    },
    requestLocationAndWeather() {
      uni.getLocation({
        type: 'wgs84',
        success: (loc) => {
          const latitude = loc.latitude
          const longitude = loc.longitude
          console.log('[weather] location success', latitude, longitude)
          this.fetchWeather(latitude, longitude)
        },
        fail: (err) => {
          console.log('[weather] getLocation failed', err)
          this.weatherMetaLabel = '非实时天气'
        },
      })
    },
    refreshWeather() {
      uni.removeStorageSync('todayWeather')
      this.loadRealWeather(true)
    },
    fetchWeather(latitude: number, longitude: number) {
      console.log('[weather] fetch Open-Meteo')
      uni.request({
        url: `https://api.open-meteo.com/v1/forecast?latitude=${latitude}&longitude=${longitude}&current=temperature_2m,relative_humidity_2m,weather_code,wind_speed_10m&timezone=auto`,
        method: 'GET',
        success: (res) => {
          console.log('[weather] Open-Meteo response', res.statusCode)
          const data = res.data as any
          if (res.statusCode != 200 || data?.current == null) {
            this.weatherMetaLabel = '非实时天气'
            return
          }
          uni.setStorageSync('todayWeather', { time: Date.now(), data: data.current })
          this.applyWeather(data.current)
        },
        fail: (err) => {
          console.log('[weather] Open-Meteo failed', err)
          this.weatherMetaLabel = '非实时天气'
        },
      })
    },
    applyWeather(current: any) {
      const temp = Math.round(Number(current?.temperature_2m))
      const humidity = Math.round(Number(current?.relative_humidity_2m))
      const wind = Math.round(Number(current?.wind_speed_10m))
      const code = Math.round(Number(current?.weather_code))
      if (!isNaN(temp)) this.weatherTemp = `${temp}°`
      if (!isNaN(humidity)) this.weatherHumidity = `${humidity}%`
      if (!isNaN(wind)) this.weatherWind = `${wind}km/h`
      this.weatherMetaLabel = '实时天气'
      this.weatherAirQuality = '实况'
      this.mood = this.weatherMoodFromCode(code)
    },
    weatherMoodFromCode(code: number): WeatherMood {
      if (code == 0 || code == 1) {
        return { title: '晴光', desc: '阳光很好 适合把今天过得松弛一点', className: 'sunny' }
      }
      if (code == 2 || code == 3 || code == 45 || code == 48) {
        return { title: '云柔', desc: '云层很轻 今天适合慢慢整理心情', className: 'cloudy' }
      }
      if ((code >= 51 && code <= 67) || (code >= 80 && code <= 82) || (code >= 95 && code <= 99)) {
        return { title: '微雨', desc: '把情绪放轻 给自己一点安静时间', className: 'rainy' }
      }
      if (code >= 71 && code <= 77) {
        return { title: '云柔', desc: '天气清冷 适合喝点热的再开始', className: 'cloudy' }
      }
      return moods[0]
    },
    getSiliconFlowKey(): string {
      const key = uni.getStorageSync('siliconFlowApiKey')
      return safeText(key)
    },
    loadDailyLine() {
      const cachedKey = `daily_line_${this.dayKey}`
      const cached = safeText(uni.getStorageSync(cachedKey))
      if (cached.length > 0) {
        this.encouragement = cached
        return
      }
      const key = this.getSiliconFlowKey()
      if (key.length == 0) return
      this.generateEncouragement(key, cachedKey)
    },
    generateEncouragement(key: string, cachedKey: string) {
      if (this.isGeneratingLine) return
      this.isGeneratingLine = true
      this.callSiliconFlow(
        key,
        `请输出一句真实中文名人名言，附作者。适合日常自我鼓励。只输出一句，不要解释，不超过32个字。`,
        (text: string) => {
          this.isGeneratingLine = false
          if (text.length > 0) {
            this.encouragement = text
            uni.setStorageSync(cachedKey, text)
          }
        },
        () => {
          this.isGeneratingLine = false
        },
        80,
        0.3,
      )
    },
    generateStory() {
      if (this.isGeneratingStory) return
      if (this.story.length > 0) {
        this.showDailyStoryTip()
        return
      }
      const cachedKey = `daily_story_${this.dayKey}`
      const cached = safeText(uni.getStorageSync(cachedKey))
      if (cached.length > 0) {
        this.story = cached
        this.storyExpanded = false
        this.showDailyStoryTip()
        return
      }
      const key = this.getSiliconFlowKey()
      if (key.length == 0) {
        uni.showToast({ title: '请先在设置中填写硅基流动 Key', icon: 'none' })
        return
      }
      this.isGeneratingStory = true
      this.callSiliconFlow(
        key,
        `请为 ${this.dayKey} 写一个今日小故事。风格温柔、励志、有画面感，主角是一个普通但认真生活的人。控制在120字以内，不要标题，不要表情符号。`,
        (text: string) => {
          this.isGeneratingStory = false
          if (text.length > 0) {
            this.story = text
            this.storyExpanded = false
            uni.setStorageSync(cachedKey, text)
          }
        },
        () => {
          this.isGeneratingStory = false
          uni.showToast({ title: '生成失败 请稍后再试', icon: 'none' })
        },
      )
    },
    showDailyStoryTip() {
      this.storyTipVisible = true
      setTimeout(() => {
        this.storyTipVisible = false
      }, 2200)
    },
    toggleStoryExpanded() {
      this.storyExpanded = !this.storyExpanded
    },
    callSiliconFlow(key: string, prompt: string, successCb: (text: string) => void, failCb: () => void, maxTokens: number = 256, temperature: number = 0.7) {
      uni.request({
        url: 'https://api.siliconflow.cn/v1/chat/completions',
        method: 'POST',
        timeout: 30000,
        header: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${key}`,
        },
        data: {
          model: 'deepseek-ai/DeepSeek-V4-Pro',
          messages: [
            {
              role: 'user',
              content: prompt,
            },
          ],
          temperature,
          max_tokens: maxTokens,
        },
        success: (res) => {
          console.log('[ai] SiliconFlow response', res.statusCode)
          const data = res.data as any
          if (res.statusCode == 429) {
            uni.showToast({ title: '今日免费额度暂不可用', icon: 'none' })
            failCb()
            return
          }
          const text = pickSiliconFlowText(data)
          if (text.length == 0) {
            failCb()
            return
          }
          successCb(text)
        },
        fail: (err) => {
          console.log('[ai] SiliconFlow failed', err)
          failCb()
        },
      })
    },
  },
}
</script>

<template>
  <view class="container">
    <view class="nav-header" :style="{ paddingTop: statusBarHeight + 'px' }">
      <view class="nav-content">
        <text class="nav-title">今日灵感</text>
        <text class="nav-subtitle">天气氛围 每日鼓励 轻故事</text>
      </view>
    </view>

    <scroll-view scroll-y class="main-scroll" :style="{ marginTop: navOffset + 'px' }">
      <view class="weather-card page-card card-delay-1" :class="mood.className" @click="refreshWeather">
        <view class="weather-scene">
          <view class="glow glow-main"></view>
          <view class="glow glow-soft"></view>
          <view class="sun"></view>
          <view class="moon"></view>
          <view class="mountain mountain-back"></view>
          <view class="mountain mountain-front"></view>
          <view class="cloud cloud-one"></view>
          <view class="cloud cloud-two"></view>
          <view class="cloud cloud-three"></view>
          <view class="rain-layer rain-back">
            <view class="rain-line"></view>
            <view class="rain-line"></view>
            <view class="rain-line"></view>
          </view>
          <view class="rain-layer rain-mid">
            <view class="rain-line"></view>
            <view class="rain-line"></view>
            <view class="rain-line"></view>
          </view>
          <view class="rain-layer rain-front">
            <view class="rain-line"></view>
            <view class="rain-line"></view>
          </view>
          <view class="ripple ripple-one"></view>
          <view class="ripple ripple-two"></view>
          <view class="leaf leaf-one"></view>
          <view class="leaf leaf-two"></view>
          <view class="bird bird-one"></view>
          <view class="bird bird-two"></view>
          <view class="star star-one"></view>
          <view class="star star-two"></view>
          <view class="star star-three"></view>
        </view>

        <view class="weather-copy">
          <view class="weather-meta">
            <text>{{ dayKey }}</text>
            <text>{{ weatherMetaLabel }}</text>
            <text>{{ weatherCity }}</text>
          </view>
          <view class="weather-bottom">
            <view class="weather-text">
              <text class="weather-title">{{ mood.title }}</text>
              <text class="weather-desc">{{ mood.desc }}</text>
            </view>
            <view class="weather-pills">
              <view class="weather-pill">
                <view class="line-icon thermometer"></view>
                <view>
                  <text class="pill-value">{{ weatherTemp }}</text>
                  <text class="pill-label">温度</text>
                </view>
              </view>
              <view class="weather-pill">
                <view class="line-icon drop"></view>
                <view>
                  <text class="pill-value">{{ weatherHumidity }}</text>
                  <text class="pill-label">湿度</text>
                </view>
              </view>
              <view class="weather-pill">
                <view class="line-icon wind"></view>
                <view>
                  <text class="pill-value">{{ weatherWind }}</text>
                  <text class="pill-label">风速</text>
                </view>
              </view>
              <view class="weather-pill">
                <view class="line-icon leaf-icon"></view>
                <view>
                  <text class="pill-value">{{ weatherAirQuality }}</text>
                  <text class="pill-label">来源</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="quote-card page-card card-delay-2">
        <view class="quote-spark quote-spark-one"></view>
        <view class="quote-spark quote-spark-two"></view>
        <view class="petal petal-one"></view>
        <view class="petal petal-two"></view>
        <view class="quote-head">
          <view class="heart-icon"></view>
          <text class="quote-label">今日名言</text>
        </view>
        <text class="quote-text">{{ isGeneratingLine ? '正在准备今天的话...' : encouragement }}</text>
      </view>

      <view class="story-card page-card card-delay-3">
        <view class="story-head">
          <view>
            <view class="story-title-row">
              <view class="book-icon"></view>
              <text class="story-title">每日故事</text>
            </view>
            <text class="story-subtitle">DeepSeek 今日生成</text>
          </view>
          <button class="story-button" @click="generateStory">
            <view class="refresh-icon" :class="{ turning: isGeneratingStory }"></view>
            <text>{{ isGeneratingStory ? '生成中' : story.length > 0 ? '换一个' : '生成' }}</text>
          </button>
        </view>

        <view v-if="storyTipVisible" class="daily-tip">
          <text class="daily-tip-title">今天就这一篇</text>
          <text class="daily-tip-text">你当 AI 是皇上吗？今天就召见一次。（认真脸）</text>
        </view>

        <view class="story-cover">
          <view class="cover-glow"></view>
          <view class="cover-window"></view>
          <view class="cover-curtain"></view>
          <view class="cover-table"></view>
          <view class="cover-cup"></view>
          <view class="cover-book"></view>
          <view class="cover-plant plant-left"></view>
          <view class="cover-plant plant-right"></view>
        </view>

        <view class="story-body">
          <text :class="{ 'story-text': true, expanded: storyExpanded }">{{ story.length > 0 ? story : '点击生成 让今天拥有一个小小的开场。' }}</text>
          <button v-if="story.length > 80" class="story-expand" @click="toggleStoryExpanded">
            {{ storyExpanded ? '收起' : '展开全文' }}
          </button>
        </view>
      </view>

      <view class="bottom-safe"></view>
    </scroll-view>
  </view>
</template>

<style>
.container {
  min-height: 100vh;
  background: #fff8f6;
}

