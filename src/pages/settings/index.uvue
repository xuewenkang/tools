<script lang="uts">
type SettingItem = {
  id: string
  label: string
  desc: string
  value: string
  type: 'info' | 'action'
}

function zodiacFromBirthday(birthday: string): string {
  const parts = birthday.split('-')
  if (parts.length < 3) return '星座'
  const month = Number(parts[1])
  const day = Number(parts[2])
  const value = month * 100 + day
  if (value >= 321 && value <= 419) return '白羊座'
  if (value >= 420 && value <= 520) return '金牛座'
  if (value >= 521 && value <= 621) return '双子座'
  if (value >= 622 && value <= 722) return '巨蟹座'
  if (value >= 723 && value <= 822) return '狮子座'
  if (value >= 823 && value <= 922) return '处女座'
  if (value >= 923 && value <= 1023) return '天秤座'
  if (value >= 1024 && value <= 1122) return '天蝎座'
  if (value >= 1123 && value <= 1221) return '射手座'
  if (value >= 1222 || value <= 119) return '摩羯座'
  if (value >= 120 && value <= 218) return '水瓶座'
  return '双鱼座'
}

function daysInMonth(year: number, month: number): number {
  return new Date(year, month, 0).getDate()
}

function formatBirthday(year: number, month: number, day: number): string {
  const m = `${month}`.padStart(2, '0')
  const d = `${day}`.padStart(2, '0')
  return `${year}-${m}-${d}`
}

export default {
  data() {
    return {
      statusBarHeight: 44,
      navOffset: 148,
      apiKeyInput: '',
      hasSiliconFlowKey: false,
      feedbackVisible: false,
      profileName: '',
      profileBirthday: '',
      profileZodiac: '',
      profileDraftName: '',
      profileDraftBirthday: '2000-01-01',
      profileDraftYear: 2000,
      profileDraftMonth: 1,
      profileDraftDay: 1,
      profileEditorVisible: false,
      items: [
        { id: 'privacy', label: '本地处理', desc: '图片处理默认在设备本地完成', value: '开启', type: 'info' as SettingItem['type'] },
        { id: 'ai', label: 'AI 灵感', desc: '默认使用 硅基流动 平台及 DeepSeek/Qwen 兼容模型', value: '可配置', type: 'info' as SettingItem['type'] },
        { id: 'cache', label: '临时缓存', desc: '清理选择图片时产生的临时记录', value: '清理', type: 'action' as SettingItem['type'] },
        { id: 'feedback', label: '意见反馈', desc: '告诉我们你希望增加的图片工具', value: '发送', type: 'action' as SettingItem['type'] },
        { id: 'version', label: '版本', desc: '图片小工具', value: 'v1.0.0', type: 'info' as SettingItem['type'] },
      ] as SettingItem[],
    }
  },
  onShow() {
    const sysInfo = uni.getSystemInfoSync()
    this.statusBarHeight = (sysInfo.statusBarHeight as number) ?? 44
    const key = uni.getStorageSync('siliconFlowApiKey')
    const text = key == null ? '' : `${key}`
    this.apiKeyInput = text
    this.hasSiliconFlowKey = text.trim().length > 0
    this.loadProfile()
  },
  methods: {
    loadProfile() {
      const saved = uni.getStorageSync('userProfile') as any
      const name = saved == null ? '' : `${saved.name ?? ''}`
      const birthday = saved == null ? '' : `${saved.birthday ?? ''}`
      const zodiac = saved == null ? '' : `${saved.zodiac ?? ''}`
      this.profileName = name.trim()
      this.profileBirthday = birthday.trim()
      this.profileZodiac = zodiac.trim()
      if (this.profileBirthday.length > 0 && this.profileZodiac.length == 0) this.profileZodiac = zodiacFromBirthday(this.profileBirthday)
      this.profileDraftName = this.profileName
      this.profileDraftBirthday = this.profileBirthday.length > 0 ? this.profileBirthday : '2000-01-01'
      this.syncDraftPartsFromBirthday(this.profileDraftBirthday)
    },
    openProfileEditor() {
      this.profileDraftName = this.profileName
      this.profileDraftBirthday = this.profileBirthday.length > 0 ? this.profileBirthday : '2000-01-01'
      this.syncDraftPartsFromBirthday(this.profileDraftBirthday)
      this.profileEditorVisible = true
    },
    closeProfileEditor() {
      this.profileEditorVisible = false
    },
    onProfileNameInput(e: any) {
      this.profileDraftName = `${e.detail.value}`
    },
    syncDraftPartsFromBirthday(birthday: string) {
      const parts = birthday.split('-')
      if (parts.length < 3) return
      const year = Number(parts[0])
      const month = Number(parts[1])
      const day = Number(parts[2])
      if (isNaN(year) || isNaN(month) || isNaN(day)) return
      this.profileDraftYear = year
      this.profileDraftMonth = Math.min(12, Math.max(1, month))
      const maxDay = daysInMonth(this.profileDraftYear, this.profileDraftMonth)
      this.profileDraftDay = Math.min(maxDay, Math.max(1, day))
      this.profileDraftBirthday = formatBirthday(this.profileDraftYear, this.profileDraftMonth, this.profileDraftDay)
    },
    syncDraftBirthdayFromParts() {
      const maxDay = daysInMonth(this.profileDraftYear, this.profileDraftMonth)
      if (this.profileDraftDay > maxDay) this.profileDraftDay = maxDay
      this.profileDraftBirthday = formatBirthday(this.profileDraftYear, this.profileDraftMonth, this.profileDraftDay)
    },
    changeDraftYear(delta: number) {
      const next = this.profileDraftYear + delta
      this.profileDraftYear = Math.min(2026, Math.max(1920, next))
      this.syncDraftBirthdayFromParts()
    },
    changeDraftMonth(delta: number) {
      let next = this.profileDraftMonth + delta
      if (next > 12) next = 1
      if (next < 1) next = 12
      this.profileDraftMonth = next
      this.syncDraftBirthdayFromParts()
    },
    changeDraftDay(delta: number) {
      const maxDay = daysInMonth(this.profileDraftYear, this.profileDraftMonth)
      let next = this.profileDraftDay + delta
      if (next > maxDay) next = 1
      if (next < 1) next = maxDay
      this.profileDraftDay = next
      this.syncDraftBirthdayFromParts()
    },
    saveProfile() {
      const name = this.profileDraftName.trim()
      if (name.length == 0) {
        uni.showToast({ title: '昵称不能为空', icon: 'none' })
        return
      }
      this.syncDraftBirthdayFromParts()
      const birthday = this.profileDraftBirthday
      const zodiac = zodiacFromBirthday(birthday)
      uni.setStorageSync('userProfile', { name, birthday, zodiac })
      this.profileName = name
      this.profileBirthday = birthday
      this.profileZodiac = zodiac
      this.profileEditorVisible = false
      uni.showToast({ title: '资料已保存', icon: 'success' })
    },
    onApiKeyInput(e: any) {
      this.apiKeyInput = `${e.detail.value}`
    },
    saveApiKey() {
      const key = this.apiKeyInput.trim()
      if (key.length == 0) {
        uni.showToast({ title: '请输入硅基流动 Key', icon: 'none' })
        return
      }
      uni.setStorageSync('siliconFlowApiKey', key)
      this.hasSiliconFlowKey = true
      uni.showToast({ title: '已保存', icon: 'success' })
    },
    clearApiKey() {
      uni.removeStorageSync('siliconFlowApiKey')
      this.apiKeyInput = ''
      this.hasSiliconFlowKey = false
      uni.showToast({ title: '已清除', icon: 'none' })
    },
    handleSetting(item: SettingItem) {
      if (item.id == 'cache') {
        uni.showToast({ title: '缓存已清理', icon: 'success' })
        return
      }
      if (item.id == 'feedback') {
        this.feedbackVisible = true
      }
    },
    closeFeedback() {
      this.feedbackVisible = false
    },
  },
}
</script>

<template>
  <view class="container">
    <view class="nav-header" :style="{ paddingTop: statusBarHeight + 'px' }">
      <view class="nav-content">
        <text class="nav-title">设置</text>
        <text class="nav-subtitle">全局偏好放这里 工具参数进工具里</text>
      </view>
    </view>

    <scroll-view scroll-y class="main-scroll" :style="{ marginTop: navOffset + 'px' }">
      <view class="summary-card">
        <text class="summary-title">图片小工具</text>
        <text class="summary-desc">一个逐步扩展的本地图片工具箱。</text>
      </view>

      <view class="profile-card">
        <view class="profile-main">
          <view class="profile-avatar">
            <text>{{ profileName.length > 0 ? profileName.slice(0, 1) : '星' }}</text>
          </view>
          <view>
            <text class="profile-name">{{ profileName.length > 0 ? profileName : '还没填写名字' }}</text>
            <text class="profile-meta">{{ profileBirthday.length > 0 ? profileBirthday + ' · ' + profileZodiac : '用于今日星座运势' }}</text>
          </view>
        </view>
        <button class="profile-edit" @click="openProfileEditor">{{ profileName.length > 0 ? '编辑' : '填写' }}</button>
      </view>

      <view class="key-card">
        <view class="key-head">
          <view>
            <text class="key-title">硅基流动 API Key</text>
            <text class="key-desc">{{ hasSiliconFlowKey ? '已配置 使用 DeepSeek/Qwen 兼容模型' : '用于今日灵感的 AI 文案和小故事' }}</text>
          </view>
          <button class="key-clear" @click="clearApiKey" v-if="hasSiliconFlowKey">清除</button>
        </view>
        <input
          class="key-input"
          type="text"
          password
          placeholder="粘贴你的 SiliconFlow API Key"
          :value="apiKeyInput"
          @input="onApiKeyInput"
        />
        <button class="key-save" @click="saveApiKey">保存 Key</button>
      </view>

      <view class="setting-group">
        <view
          v-for="(item, index) in items"
          :key="item.id"
          class="setting-row"
          :class="{ bordered: index < items.length - 1 }"
          @click="handleSetting(item)"
        >
          <view class="row-main">
            <text class="row-label">{{ item.label }}</text>
            <text class="row-desc">{{ item.desc }}</text>
          </view>
          <view class="row-side">
            <text :class="{ value: true, action: item.type == 'action' }">{{ item.value }}</text>
            <text v-if="item.type == 'action'" class="chevron">›</text>
          </view>
        </view>
      </view>

      <view class="bottom-note">
        <text>拼图的比例 样式 导出质量等参数在拼图页单独设置 避免全局设置越来越乱。</text>
      </view>

      <view class="bottom-safe"></view>
    </scroll-view>

    <view v-if="feedbackVisible" class="feedback-mask" @click="closeFeedback"></view>
    <view v-if="feedbackVisible" class="feedback-dialog">
      <view class="feedback-shine"></view>
      <text class="feedback-title">你什么档次也反馈？</text>
      <text class="feedback-text">不过朕准了。你的想法很重要，先记在小本本上。</text>
      <button class="feedback-button" @click="closeFeedback">退下吧</button>
    </view>

    <view v-if="profileEditorVisible" class="feedback-mask" @click="closeProfileEditor"></view>
    <view v-if="profileEditorVisible" class="profile-dialog">
      <view class="feedback-shine"></view>
      <text class="feedback-title">编辑个人档案</text>
      <text class="feedback-text">名字和生日只保存在本机，用来计算星座和生成今日运势。</text>
      <input class="profile-input" placeholder="你的名字" :value="profileDraftName" @input="onProfileNameInput" />

      <view class="date-selector">
        <view class="date-selector-head">
          <text>出生日期</text>
          <text>{{ profileDraftBirthday }}</text>
        </view>
        <view class="date-columns">
          <view class="date-column">
            <button class="date-step up" @click="changeDraftYear(1)"></button>
            <text class="date-value">{{ profileDraftYear }}</text>
            <text class="date-unit">年</text>
            <button class="date-step down" @click="changeDraftYear(-1)"></button>
          </view>
          <view class="date-column">
            <button class="date-step up" @click="changeDraftMonth(1)"></button>
            <text class="date-value">{{ profileDraftMonth }}</text>
            <text class="date-unit">月</text>
            <button class="date-step down" @click="changeDraftMonth(-1)"></button>
          </view>
          <view class="date-column">
            <button class="date-step up" @click="changeDraftDay(1)"></button>
            <text class="date-value">{{ profileDraftDay }}</text>
            <text class="date-unit">日</text>
            <button class="date-step down" @click="changeDraftDay(-1)"></button>
          </view>
        </view>
      </view>
      <button class="feedback-button" @click="saveProfile">保存</button>
    </view>
  </view>
</template>

