}

.date-column {
  flex: 1;
  min-width: 0;
  padding: 14rpx 8rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.date-step {
  width: 52rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: rgba(217, 107, 124, 0.12);
  position: relative;
}

.date-step::after {
  content: '';
  position: absolute;
  left: 17rpx;
  top: 15rpx;
  width: 15rpx;
  height: 15rpx;
  border-top: 3rpx solid #b85265;
  border-left: 3rpx solid #b85265;
  transform: rotate(45deg);
}

.date-step.down::after {
  top: 8rpx;
  transform: rotate(225deg);
